

@prefix samm: <urn:samm:org.eclipse.esmf.samm:meta-model:2.1.0#> .
@prefix samm-c: <urn:samm:org.eclipse.esmf.samm:characteristic:2.1.0#> .
@prefix samm-e: <urn:samm:org.eclipse.esmf.samm:entity:2.1.0#> .
@prefix unit: <urn:samm:org.eclipse.esmf.samm:unit:2.1.0#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <urn:samm:io.catenax.cbam:0.1.0#> .
@prefix samm-u: <urn:samm:org.eclipse.esmf.samm:unit:2.1.0#> .

:AttestationOfConformance a samm:Aspect ;
   samm:properties ( :attestationOfConformance ) ;
   samm:operations ( ) ;
   samm:events ( ) .

:attestationOfConformance a samm:Property ;
   samm:characteristic :AttestationOfConformanceCharacteristic .

:AttestationOfConformanceCharacteristic a samm:Characteristic ;
   samm:dataType :AttestationOfConformanceEntity .

:AttestationOfConformanceEntity a samm:Entity ;
   samm:properties ( :completedAt :attestationOfConformanceLink :attestationOfConformanceId :accreditationBodyName :providerId :providerName :standardName :attestationStandard :attestationType ) .

:completedAt a samm:Property ;
   samm:characteristic :FreeDateCharacteristic .

:attestationOfConformanceLink a samm:Property ;
   samm:characteristic :FreeTextCharacteristic .

:attestationOfConformanceId a samm:Property ;
   samm:characteristic :FreeTextCharacteristic .

:accreditationBodyName a samm:Property ;
   samm:characteristic :FreeTextCharacteristic .

:providerId a samm:Property ;
   samm:characteristic :FreeTextCharacteristic .

:providerName a samm:Property ;
   samm:characteristic :FreeTextCharacteristic .

:standardName a samm:Property ;
   samm:characteristic :FreeTextCharacteristic .

:attestationStandard a samm:Property ;
   samm:characteristic :FreeTextCharacteristic .

:attestationType a samm:Property ;
   samm:characteristic :FreeTextCharacteristic .

:FreeDateCharacteristic a samm:Characteristic ;
   samm:dataType xsd:date .

:FreeTextCharacteristic a samm:Characteristic ;
   samm:dataType xsd:string .

