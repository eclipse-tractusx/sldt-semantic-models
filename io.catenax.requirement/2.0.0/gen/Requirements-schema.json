{
  "$schema" : "http://json-schema.org/draft-04/schema",
  "x-samm-aspect-model-urn" : "urn:samm:io.catenax.requirements:2.0.0#Requirements",
  "description" : "Aspect model for requirements engineering in a customer supplier relationship.",
