@prefix samm: <urn:samm:org.eclipse.esmf.samm:meta-model:2.2.0#> .
@prefix samm-c: <urn:samm:org.eclipse.esmf.samm:characteristic:2.2.0#> .
@prefix samm-e: <urn:samm:org.eclipse.esmf.samm:entity:2.2.0#> .
@prefix unit: <urn:samm:org.eclipse.esmf.samm:unit:2.1.0#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <urn:samm:io.catenax.requirements.shared:1.0.0#> .


### from externals (not shared yet)

:RequirementsShared a samm:Aspect ;
   samm:preferredName "Shared Requirements Aspect"@en ;
   samm:description "Aspect MOdel for shared properties related to requirements engineering."@en ;
   samm:properties ( 
      :binaryDocument 
   ) ;
   samm:operations ( ) ;
   samm:events ( ) .



### Certificate of Analysis v2.0.0

:binaryDocument a samm:Property ;
   samm:preferredName "binary document"@en ;
   samm:description "A binary representation of the Certificate of Analysis as a Base64-encoded document (e.g., PDF). This allows embedding the original document directly within the data payload."@en ;
   samm:characteristic :BinaryDocumentCharacteristic .

:BinaryDocumentCharacteristic a samm:Characteristic ;
   samm:preferredName "binary document characteristic"@en ;
   samm:description "Characteristic for a Base64-encoded binary document attachment."@en ;
   samm:dataType :BinaryDocumentEntity .

:BinaryDocumentEntity a samm:Entity ;
   samm:preferredName "binary document entity"@en ;
   samm:description "Entity representing a Base64-encoded binary document with its metadata. The binary file (e.g., PDF) is encoded using Base64 encoding for safe transport through text-based systems."@en ;
   samm:properties ( 
      :payload 
      :mimeType  
      ) .

:payload a samm:Property ;
   samm:preferredName "payload"@en ;
   samm:description "Base64-encoded string of the binary document file (e.g., PDF)."@en ;
   samm:characteristic :PayloadCharacteristic ;
   samm:exampleValue "JVBERi0xLjQKJeLjz9MKMyAwIG9iago8PAovVHlwZSAvUGFnZQo" ^^xsd:base64Binary .

:PayloadCharacteristic a samm:Characteristic ;
   samm:preferredName "payload characteristic"@en ;
   samm:description "Base64 binary encoded content."@en ;
   samm:dataType xsd:base64Binary .

:mimeType a samm:Property ;
   samm:preferredName "MIME type"@en ;
   samm:description "The MIME type of the encoded document (e.g., application/pdf)."@en ;
   samm:characteristic samm-c:Text ;
   samm:exampleValue "image/jpeg" .

