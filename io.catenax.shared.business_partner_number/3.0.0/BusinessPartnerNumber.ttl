@prefix samm: <urn:samm:org.eclipse.esmf.samm:meta-model:2.1.0#> .
@prefix samm-c: <urn:samm:org.eclipse.esmf.samm:characteristic:2.1.0#> .
@prefix samm-e: <urn:samm:org.eclipse.esmf.samm:entity:2.1.0#> .
@prefix unit: <urn:samm:org.eclipse.esmf.samm:unit:2.1.0#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <urn:samm:io.catenax.shared.business_partner_number:3.0.0#> .

:BusinessPartnerNumber a samm:Aspect;
    samm:preferredName "Shared Aspect for any business partner number"@en;
    samm:description "This is a shared aspect for BPN with a regex."@en;
    samm:properties (:bpnl :bpns :bpna);
    samm:operations ();
    samm:events ().

:bpna a samm:Property ;
   samm:preferredName "Business Partner Number Address"@en ;
   samm:description "Property based on a Business Partner Number Address (BPNA)."@en ;
   samm:characteristic :BpnaTrait ;
   samm:exampleValue "BPNA0123456789ZZ" .

:BpnaTrait a samm-c:Trait ;
   samm:preferredName "Business Partner Number Address Trait"@en ;
   samm:description "Trait to ensure data format for Business Partner Number Address (BPNA)."@en ;
   samm-c:baseCharacteristic :BpnaCharacteristic ;
   samm-c:constraint :BpnaRegularExpression .

:BpnaCharacteristic a samm:Characteristic ;
   samm:preferredName "Business Partner Number Site"@en ;
   samm:description "Business Partner Number Address (BPNA) contains the legal name (incl. legal form, if registered) and additional organization information about site, e.g. Plant xxx, Branch office yyy of an organization with its corresponding, most commonly physical, address. A BPNA is always linked to a BPNL via relationship 'belongs to legal entity' and should be linked to a BPNS via relationship 'belongs to site'. The BPNA is on operational level (e.g. shipping or pick-up address)."@en ;
   samm:dataType xsd:string .

:BpnaRegularExpression a samm-c:RegularExpressionConstraint ;
   samm:preferredName "Business Partner Number Address Regular Expression"@en ;
   samm:description "The provided regular expression ensures that the Business Partner Number Address (BPNA) is composed of prefix 'BPNA', 10 digits and two alphanumeric letters."@en ;
   samm:value "^BPNA[a-zA-Z0-9]{12}$" .

:AnyBpnCharacteristic a samm-c:StructuredValue ;
   samm:preferredName "any Business Partner Number charcteristic"@en ;
   samm:description "allows the use of any Business Partner Number (BPN)"@en ;
   samm:dataType xsd:string ;
   samm-c:deconstructionRule "^(BPNL[a-zA-Z0-9]{12})|(BPNS[a-zA-Z0-9]{12})|(BPNA[a-zA-Z0-9]{12})$" ;
   samm-c:elements ( "^" :bpnl "|" :bpns "|" :bpna "$" ) .

:bpns a samm:Property ;
   samm:preferredName "Business Partner Number Site Property"@en ;
   samm:description "Property based on a Business Partner Number Site (BPNS)."@en ;
   samm:characteristic :BpnsTrait ;
   samm:exampleValue "BPNS0123456789ZZ" .

:BpnsRegularExpression a samm-c:RegularExpressionConstraint ;
   samm:preferredName "Business Partner Number Site regular expression"@en ;
   samm:description "The provided regular expression ensures that the BPNS is composed of prefix 'BPNS', 10 digits and two alphanumeric letters."@en ;
   samm:value "^BPNS[a-zA-Z0-9]{12}$" .

:BpnsCharacteristic a samm:Characteristic ;
   samm:preferredName "Business Partner Number Site"@en ;
   samm:description "Business Partner Number Site (BPNS) represents a site which can be a production plant. A site can also be e.g. an office or a warehouse. An information related to a site is e.g. needed for reporting issues (How many sites does e.g. Beispiel AG have?), status of operation (out of operations due to environmental disaster), for certificates on site level (e.g. environment certificates) or for internal regulations on site level, (e.g. security topics, Corona rules,...). Several addresses (= BPNA with different streets and different gates) can belong to one site. A BPNS should be always linked to one BPNL via relationship 'belongs to legal entity'."@en ;
   samm:dataType xsd:string .

:BpnlTrait a samm-c:Trait ;
   samm:preferredName "Business Partner Number Legal Trait"@en ;
   samm:description "Trait to ensure data format for Business Partner Number Legal (BPNL)."@en ;
   samm-c:baseCharacteristic :BpnlCharacteristic ;
   samm-c:constraint :BpnlRegularExpression .

:bpnl a samm:Property ;
   samm:preferredName "Business Partner Number Legal Entity Property"@en ;
   samm:description "Property based on a Business Partner Number Legal (BPNL)."@en ;
   samm:characteristic :BpnlTrait ;
   samm:exampleValue "BPNL0123456789ZZ" .

:BpnsTrait a samm-c:Trait ;
   samm:preferredName "Business Partner Number Site Trait"@en ;
   samm:description "Trait to ensure data format for Business Partner Number Site (BPNS)."@en ;
   samm-c:baseCharacteristic :BpnsCharacteristic ;
   samm-c:constraint :BpnsRegularExpression .

:BpnlCharacteristic a samm:Characteristic ;
   samm:preferredName "Business Partner Number Legal Entity"@en ;
   samm:description "Business Partner Number Legal Entity (BPNL) represents the legal entity of an organization (e.g. enterprise, university, association, …) and contains its legal name (incl. legal form, if registered), registered address and tax number. The registered address is the official, legal correspondence address which has to be supplied to governmental and tax authorities and is the address which is used in any legal or court documents. BPNL is on corporate level and is unique for this legal entity."@en ;
   samm:dataType xsd:string .

:BpnsOrBpnaCharacteristic a samm-c:StructuredValue ;
   samm:preferredName "Business Partner Number Site or Address Characteristic"@en ;
   samm:description "This characteristic allows Business Partner Number Site (BPNS) or Address (BPNA)."@en ;
   samm:dataType xsd:string ;
   samm-c:deconstructionRule "^(BPNS[a-zA-Z0-9]{12})|(BPNA[a-zA-Z0-9]{12})$" ;
   samm-c:elements ( :bpns :bpna ) .

:BpnlRegularExpression a samm-c:RegularExpressionConstraint ;
   samm:preferredName "Business Partner Number Legal Entity Regular Expression"@en ;
   samm:description "The provided regular expression ensures that the Business Partner Number Legal Entity (BPNL) is composed of prefix 'BPNL', 10 digits and two alphanumeric letters."@en ;
   samm:value "^BPNL[a-zA-Z0-9]{12}$" .

