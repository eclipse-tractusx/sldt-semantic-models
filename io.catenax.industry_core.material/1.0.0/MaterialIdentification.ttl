

@prefix samm: <urn:samm:org.eclipse.esmf.samm:meta-model:2.1.0#> .
@prefix samm-c: <urn:samm:org.eclipse.esmf.samm:characteristic:2.1.0#> .
@prefix samm-e: <urn:samm:org.eclipse.esmf.samm:entity:2.1.0#> .
@prefix unit: <urn:samm:org.eclipse.esmf.samm:unit:2.1.0#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <urn:samm:io.catenax.industry_core.material:1.0.0#> .
@prefix ext-classification: <urn:samm:io.catenax.shared.industry_core.asset_classification:1.0.0#> .
@prefix ext-common: <urn:samm:io.catenax.shared.industry_core.common:1.0.0#> .
@prefix samm-u: <urn:samm:org.eclipse.esmf.samm:unit:2.1.0#> .

:MaterialIdentification a samm:Aspect ;
   samm:preferredName "Material Identification"@en ;
   samm:description "contains all properties required to uniquely and unambiguously identify a material"@en ;
   samm:properties ( ext-common:globalAssetId [ samm:property :customerMaterialId; samm:optional true ] [ samm:property :nameAtCustomer; samm:optional true ] [ samm:property :manufacturerMaterialId; samm:optional true ] [ samm:property :nameAtManufacturer; samm:optional true ] ext-classification:classification ) ;
   samm:operations ( ) ;
   samm:events ( ) .

:customerMaterialId a samm:Property ;
   samm:preferredName "Customer material ID"@en ;
   samm:description "Material ID as assigned by the customer of the material. The customer material ID identifies the material in the customer`s internal system."@en ;
   samm:characteristic :MaterialIdCharacteristic .

:nameAtCustomer a samm:Property ;
   samm:preferredName "Name at customer"@en ;
   samm:description "Name of the part as assigned by the customer"@en ;
   samm:characteristic samm-c:Text .

:manufacturerMaterialId a samm:Property ;
   samm:preferredName "Manufacturer material ID"@en ;
   samm:description "Material ID as assigned by the manufacturer of the material. The manufacturer material ID identifies the material in the manufacturer`s internal system."@en ;
   samm:characteristic :MaterialIdCharacteristic .

:nameAtManufacturer a samm:Property ;
   samm:preferredName "Name at manufacturer"@en ;
   samm:description "Name of the part as assigned by the manufacturer"@en ;
   samm:characteristic samm-c:Text .

:MaterialIdCharacteristic a samm-c:Code ;
   samm:preferredName "MaterialIdCharacteristic"@en ;
   samm:description "identifier of a material"@en ;
   samm:dataType xsd:string .

