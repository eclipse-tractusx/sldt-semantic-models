

@prefix samm: <urn:samm:org.eclipse.esmf.samm:meta-model:2.1.0#> .
@prefix samm-c: <urn:samm:org.eclipse.esmf.samm:characteristic:2.1.0#> .
@prefix samm-e: <urn:samm:org.eclipse.esmf.samm:entity:2.1.0#> .
@prefix unit: <urn:samm:org.eclipse.esmf.samm:unit:2.1.0#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <urn:samm:io.catenax.industry_core.material:1.0.0#> .
@prefix samm-u: <urn:samm:org.eclipse.esmf.samm:unit:2.1.0#> .

:max a samm:Property ;
   samm:preferredName "max"@en ;
   samm:description "Maximum value of the content"@en ;
   samm:characteristic :PercentTrait ;
   samm:exampleValue "35.6"^^xsd:float .

:PercentTrait a samm-c:Trait ;
   samm:preferredName "PercentTrait"@en ;
   samm-c:baseCharacteristic :FloatPercent ;
   samm-c:constraint :PercentConstraint .

:FloatPercent a samm-c:Quantifiable ;
   samm:preferredName "float percent"@en ;
   samm:description "float percent"@en ;
   samm:dataType xsd:float ;
   samm-c:unit samm-u:percent .

:PercentConstraint a samm-c:RangeConstraint ;
   samm:preferredName "PercentConstraint"@en ;
   samm-c:minValue "0"^^xsd:float ;
   samm-c:maxValue "100"^^xsd:float ;
   samm-c:lowerBoundDefinition samm-c:AT_LEAST ;
   samm-c:upperBoundDefinition samm-c:AT_MOST .

:RangeMassSingleEntity a samm-c:SingleEntity ;
   samm:preferredName "RangeMassSingleEntity"@en ;
   samm:description "RangeMassSingleEntity"@en ;
   samm:dataType :RangeMassEntity .

:RangeSingleEntity a samm-c:SingleEntity ;
   samm:preferredName "RangeSingleEntity"@en ;
   samm:description "RangeSingleEntity"@en ;
   samm:dataType :RangeEntity .

:RangeMassEntity a samm:Entity ;
   samm:preferredName "Range Mass Entity"@en ;
   samm:description "Entity containing a min and max value and a massBalanced flag"@en ;
   samm:properties ( :massBalanced :max :min ) .

:min a samm:Property ;
   samm:preferredName "min"@en ;
   samm:description "Minimum value of the content"@en ;
   samm:characteristic :PercentTrait ;
   samm:exampleValue "12.0"^^xsd:float .

:massBalanced a samm:Property ;
   samm:preferredName "mass balanced"@en ;
   samm:description "Defines if the content is mass balanced. "@en ;
   samm:characteristic samm-c:Boolean .

:RangeEntity a samm:Entity ;
   samm:preferredName "Range Entity"@en ;
   samm:description "Entity containing a min and max value"@en ;
   samm:properties ( :max :min ) .

